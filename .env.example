# ---- Target ----
# Instagram username to track (no @).
TARGET_USERNAME=vozinha1

# ---- Data provider ----
# direct = free unauthenticated Instagram scrape (default)
# proxy  = same scrape routed through PROXY_URL (needs `npm i undici`)
# apify  = Apify Instagram Profile Scraper (needs APIFY_TOKEN)
FOLLOWER_PROVIDER=direct

# Optional: override the browser User-Agent used by the direct/proxy provider.
# IG_USER_AGENT=

# ---- Poll auth ----
# Guards GET/POST /api/poll. Send as `Authorization: Bearer <CRON_SECRET>`
# (Vercel Cron sends this automatically) or as ?secret=<CRON_SECRET>.
# If unset, /api/poll is open (dev convenience only — always set this in prod).
CRON_SECRET=change-me-to-a-long-random-string

# ---- Cache (production) ----
# Upstash Redis REST creds. If unset, the app falls back to an in-memory store
# (fine for local dev; NOT suitable for serverless production).
# UPSTASH_REDIS_REST_URL=
# UPSTASH_REDIS_REST_TOKEN=

# ---- Public site URL (for OG/share absolute links) ----
# NEXT_PUBLIC_SITE_URL=https://your-app.vercel.app

# ---- Escape hatches (only when FOLLOWER_PROVIDER set accordingly) ----
# PROXY_URL=http://user:pass@host:port
# APIFY_TOKEN=
